{
  "name": "bun-decompile",
  "version": "0.0.1",
  "description": "Extracts the original transpiled sources from an executable file generated via `bun build --compile`.",
  "bin": {
    "bun-decompile": "./src/cli.ts"
  },
  "files": ["src/lib/", "src/cli.ts"],
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.6.2",
    "@types/bun": "^1.2.20",
    "prettier": "^3.6.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "start": "bun src/cli.ts",
    "tests": "multibun run --from 0.6.0 -x ./src/scripts/dummyTests.sh -n --html static/tests.html",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "type": "module"
}
